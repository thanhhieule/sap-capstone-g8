projection;
strict ( 1 );
use draft;

define behavior  for ZC_ATT_G8 alias Header
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Item { create; with draft; }
}

define behavior for ZC_LIST_G8 alias Item
{
  use update;
  use association _Header { with draft; }
}